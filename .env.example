# App
APP_URL=http://localhost:3000

# Auth
AUTH_SECRET=change-me

# Database
DATABASE_URL=file:./dev.db

# Production Docker example:
# DATABASE_URL=file:/app/storage/db/prod.db

# Storage
STORAGE_DIR=./storage
MAX_UPLOAD_MB=2048

# Production Docker example:
# STORAGE_DIR=/app/storage

# AI provider
AI_PROVIDER=mock
OPENAI_API_KEY=

# FFmpeg
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
